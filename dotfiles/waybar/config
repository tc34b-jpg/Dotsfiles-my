{
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 4,
    "modules-left": ["custom/arch", "hyprland/workspaces", "custom/limbus", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["pulseaudio", "network", "cpu", "memory", "battery", "tray", "custom/power"],

    "custom/arch": {
        "format": "   ",
        "tooltip-format": "TC34b'S COMPUTER",
        "on-click": "~/.config/waybar/flatpak-launcher.sh"
    },

    "custom/limbus": {
        "format": " TC34BROOT ",
        "tooltip-format": "Face the Fear, Build the Future",
        "on-click": "rofi -combi-modi drun,run,window -show combi"
    },

    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate"
    },

    "clock": {
        "interval": 1, 
        "format": "<span>  </span>{:%H:%M}",
        "tooltip-format": "<big>It's time for linux!</big>\n<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "cpu": {
        "format": "<span> </span>{usage}%"
    },

    "memory": {
        "format": "<span></span> {avail:0.1f}G/{total:0.1f}G <span>󰓡</span> {swapUsed:0.1f}G",
        "tooltip": true,
        "tooltip-format": "RAM: {used}GiB / {total}GiB ({percentage}%)\nSwap: {swapUsed}GiB / {swapTotal}GiB ({swapPercentage}%)"
    },

    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "<span>{icon}</span> {capacity}%",
        "format-icons": ["", "", "", "", ""]
    },

    "network": {
        "format-wifi": "  {essid}",
        "tooltip": true,
        "tooltip-format": "⬇{bandwidthDownBytes} ⬆{bandwidthUpBytes} |  {signalStrength}%",
        "format-disconnected": "<span>⚠ </span>OFF",
        "interval": 1	
    },

    "pulseaudio": {
        "format": "<span>{icon}</span> {volume}%",
        "format-muted": "",
        "format-icons": { "default": ["", "", ""] },
        "on-click": "dbus-launch pavucontrol"
    },
    
    "custom/power": {
        "format": " ⏻ ",
        "tooltip": false,
        "on-click": "wlogout", 
    }
}
